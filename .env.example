# =============================================================================
#  Environment variables for the Docker stack.
#
#  SETUP:  copy this file to ".env" and fill in real values:
#              cp .env.example .env     (Linux/macOS)
#              copy .env.example .env   (Windows)
#
#  The real ".env" is gitignored and must NEVER be committed.
#  Docker Compose reads ".env" automatically for variable substitution.
# =============================================================================

# How WordPress reaches the database (service name + port on the compose network).
# Leave as-is unless you rename the mysql service.
WORDPRESS_DB_HOST=mysql:3306

# Database name. Tip: keep distinct per environment, e.g. wordpress_dev /
# wordpress_stg / wordpress_prod, so you never point dev at prod data.
MYSQL_DATABASE=wordpress

# Application DB user (used by WordPress). Do NOT use root for the app.
MYSQL_USER=changeme_user

# Strong, unique passwords. Generate, don't hand-type. For example:
#     openssl rand -base64 24
# Avoid simple/guessable values — these guard your production database.
MYSQL_PASSWORD=changeme_use_a_strong_generated_password

# MySQL root password — separate from the app user, even stronger.
MYSQL_ROOT_PASSWORD=changeme_use_a_different_strong_password
